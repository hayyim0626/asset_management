  "engines": {
    "node": "20.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "yarn test:unit",
    "test:unit": "jest --testPathIgnorePatterns=functional\\.test\\.ts$",
